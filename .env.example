# ==== DigiRep サイト 環境変数サンプル ====
# このファイルをコピーして .env.local を作成し、実値を入れてください（.env.local は Git 管理外）。
# Vercel では「Project > Settings > Environment Variables」に同じキー名で登録します。

# 本番サイトの絶対URL（Stripe の success/cancel URL 生成に使用）
NEXT_PUBLIC_SITE_URL=https://digirep.work

# ---- Stripe ----
# 公開可能キー（フロント用）: Stripe ダッシュボード「開発者 > APIキー」の "公開可能キー"（pk_ から始まる）
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# シークレットキー（サーバー専用・絶対に公開しない）: 同ページの "シークレットキー"（sk_ から始まる）
STRIPE_SECRET_KEY=
# Webhook 署名シークレット（whsec_ から始まる）: Stripe の Webhook 設定で発行
STRIPE_WEBHOOK_SECRET=

# ---- 資料請求フォーム（メール送信・任意）----
# Resend（https://resend.com）の API キーと送信先。未設定でもフォームは受付完了しますが、
# メールは送られずサーバーログに記録されます。設定するとメール通知が届きます。
RESEND_API_KEY=
LEAD_TO_EMAIL=digirep.yumoto@gmail.com
LEAD_FROM_EMAIL=DigiRep <onboarding@resend.dev>
