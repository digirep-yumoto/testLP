# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# テンプレートのみコミット可（実値ファイルは上の .env* で除外）
!.env.example

# vercel
.vercel

# ローカル開発ツール（Claude Code のスキル・設定：本番デプロイには不要）
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts
